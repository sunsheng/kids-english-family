{
  "name": "kids-english-family",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "wordbank:build": "node scripts/build-full-word-bank.mjs",
    "wordbank:build:pep": "node scripts/build-full-word-bank.mjs --only=pep",
    "wordbank:validate": "node scripts/import-word-bank.mjs data/word-bank.sample.csv --dry-run",
    "wordbank:import": "node scripts/import-word-bank.mjs data/word-bank.sample.csv",
    "wordbank:validate:full": "node --max-old-space-size=8192 scripts/import-word-bank.mjs data/generated/full-word-bank.csv --dry-run",
    "wordbank:import:full": "node --max-old-space-size=8192 scripts/import-word-bank.mjs data/generated/full-word-bank.csv --replace-books",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "next": "^16.0.10",
    "pg": "^8.22.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3"
  }
}
